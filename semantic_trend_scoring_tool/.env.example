# Ingest API defaults
INGEST_DEFAULT_LIMIT=25
INGEST_REQUEST_TIMEOUT_MS=10000

# Google Trends
# Uses @shaivpidadi/trends-js dailyTrends method.
GOOGLE_TRENDS_GEO=US
GOOGLE_TRENDS_LANG=en

# Reddit OAuth app credentials
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=american-water-cooler-index/0.1 by your_reddit_username
REDDIT_SUBREDDITS=news,politics,sports,technology,entertainment,business,health

# GDELT does not require an API key.
GDELT_API_ENDPOINT=https://api.gdeltproject.org/api/v2/doc/doc
GDELT_QUERY=sourcecountry:US
GDELT_TIMESPAN=24h

# NewsAPI.org top headlines
NEWS_API_ENDPOINT=https://newsapi.org/v2/top-headlines
NEWS_API_KEY=da232634-7aba-4ce7-a443-74e23ca87322
NEWS_API_COUNTRY=us

# Wikimedia Pageviews does not require an API key, but it does ask for a useful User-Agent.
WIKIMEDIA_USER_AGENT=american-water-cooler-index/0.1 (your_email@example.com)
WIKIPEDIA_PAGEVIEWS_ENDPOINT=https://wikimedia.org/api/rest_v1/metrics/pageviews/top/en.wikipedia/all-access

# TikTok Research API
# Requires TikTok Research API approval and research.data.basic scope.
TIKTOK_TOKEN_ENDPOINT=https://open.tiktokapis.com/v2/oauth/token/
TIKTOK_RESEARCH_VIDEO_QUERY_ENDPOINT=https://open.tiktokapis.com/v2/research/video/query/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_RESEARCH_FIELDS=id,video_description,create_time,region_code,share_count,view_count,like_count,comment_count,hashtag_names,username
TIKTOK_KEYWORDS=news,politics,sports,technology,entertainment,business,health
TIKTOK_REGION_CODES=US
TIKTOK_LOOKBACK_DAYS=7

# X API v2 Trends by WOEID
# Common WOEIDs: Worldwide=1, United States=23424977, New York=2459115, Los Angeles=2442047
X_TRENDS_BY_WOEID_ENDPOINT=https://api.x.com/2/trends/by/woeid
X_BEARER_TOKEN=
X_TRENDS_WOEID=23424977
X_TRENDS_MAX_TRENDS=20
X_TREND_FIELDS=trend_name,tweet_count

# Wall Street Journal / Dow Jones
# Provide your Dow Jones/WSJ API URL and key, or explicitly set current RSS feeds.
WSJ_API_URL=
WSJ_API_KEY=
WSJ_USER_AGENT=american-water-cooler-index/0.1 (your_email@example.com)
WSJ_RSS_URLS=

# New York Times Top Stories API
NYT_TOP_STORIES_ENDPOINT=https://api.nytimes.com/svc/topstories/v2
NYT_API_KEY=
NYT_TOP_STORIES_SECTION=home

# Washington Post
# If WASHINGTON_POST_API_URL and WASHINGTON_POST_API_KEY are provided, the ingest uses that JSON API.
# Otherwise it reads the configured Washington Post RSS feeds.
WASHINGTON_POST_API_URL=
WASHINGTON_POST_API_KEY=
WASHINGTON_POST_USER_AGENT=american-water-cooler-index/0.1 (your_email@example.com)
WASHINGTON_POST_RSS_URLS=https://feeds.washingtonpost.com/rss/politics,https://feeds.washingtonpost.com/rss/national,https://feeds.washingtonpost.com/rss/world,https://feeds.washingtonpost.com/rss/business,https://feeds.washingtonpost.com/rss/business/technology,https://feeds.washingtonpost.com/rss/lifestyle,https://feeds.washingtonpost.com/rss/entertainment
